{
  "manifest_version": 3,
  "name": "Sekme Gruplayıcı & RAM Optimize Edici",
  "version": "1.0",
  "description": "Sekmeleri gruplar ve RAM kullanımını optimize eder",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}